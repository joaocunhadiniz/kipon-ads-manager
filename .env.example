# Google Ads API Credentials
# Para obter essas credenciais, siga o guia em CREDENTIALS_GUIDE.md

# Developer Token (obtido em https://ads.google.com/aw/apicenter)
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 Credentials (obtidos no Google Cloud Console)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Refresh Token (gerado após autorização OAuth2)
GOOGLE_ADS_REFRESH_TOKEN=

# Customer ID (ID da conta Google Ads, formato: 123-456-7890)
GOOGLE_ADS_CUSTOMER_ID=

# Login Customer ID (opcional, use se estiver gerenciando contas de clientes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Supabase (obter no painel do projeto Lovable → Supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude (para análise semanal com IA)
ANTHROPIC_API_KEY=
